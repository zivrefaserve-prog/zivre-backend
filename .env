# ==================== FLASK CONFIGURATION ====================
SECRET_KEY=zivre-super-secret-key-change-in-production-2024
FLASK_ENV=development

# ==================== DATABASE ====================
DATABASE_URL=sqlite:///zivre.db

# ==================== CORS ORIGINS ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# ==================== RATE LIMITING ====================
RATELIMIT_STORAGE_URL=memory://

# ==================== FILE UPLOADS ====================
MAX_CONTENT_LENGTH=52428800
UPLOAD_FOLDER=uploads
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,webp,mp3,m4a,wav,mp4,pdf,doc,docx,txt,xlsx,pptx,csv,zip,rar

# ==================== EMAIL CONFIGURATION (GMAIL SMTP) ====================
# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=zivrefaserve@gmail.com
MAIL_PASSWORD=jmivcbvhipysvgcl
MAIL_DEFAULT_SENDER=zivrefaserve@gmail.com
MAIL_USE_TLS=True
FRONTEND_URL=http://localhost:3000

# ==================== WEBSOCKET CONFIGURATION ====================
SOCKET_URL=http://localhost:5000

# ==================== SESSION CONFIGURATION ====================
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
